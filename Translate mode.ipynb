"""
Gender‑Aware Translation Framework for Dataset
Detects gender ambiguity, injects explicit gender markers,
and produces separate translations for masculine/feminine interpretations.
"""
import re
from typing import List, Tuple, Optional

import spacy
from googletrans import Translator

# 1. Configuration
TARGET_LANG = "fr"          # French 
def load_occupations(filepath: str = "../data/Occupation.txt") -> set:
    with open(filepath, "r", encoding="utf-8") as f:
        # Strip whitespace, keep non-empty lines, lowercase
        return {line.strip().lower() for line in f if line.strip()}
    
def load_sentences(filepath: str = "data/eval_inputs.txt") -> List[str]:
    with open(filepath, "r", encoding="utf-8") as f:
        return [line.strip() for line in f if line.strip()]

OCCUPATION_LIST = load_occupations()

GENDER_MARKERS = {
    "male", "female", "man", "woman", "boy", "girl",
    "he", "she", "him", "her", "his", "hers", "himself", "herself"
}

nlp = spacy.load("en_core_web_sm")
translator = Translator()

# 2. Helper Functions

def is_ambiguous(sentence: str) -> bool:
    """
    Returns True if the sentence contains no explicit gender markers.
    """
    sent_lower = sentence.lower()
    # Check for any gender marker word
    for marker in GENDER_MARKERS:
        if re.search(rf"\b{marker}\b", sent_lower):
            return False
    return True

def find_occupation(sentence: str) -> Optional[str]:
    """
    Finds the first occupation noun (lemma) in the sentence using spaCy.
    Returns the exact token text (or None if not found).
    """
    doc = nlp(sentence)
    for token in doc:
        # Nouns that are in our occupation list (case‑insensitive)
        if token.pos_ in ("NOUN", "PROPN") and token.lemma_.lower() in OCCUPATION_LIST:
            return token.text
    return None

def inject_gender(sentence: str, occupation: str, gender: str) -> str:
    """
    Inserts 'male' or 'female' before the first occurrence of the occupation.
    Example: "the professor is going home" + "male" -> "the male professor is going home"
    """
    pattern = re.compile(rf"(\b{re.escape(occupation)}\b)", re.IGNORECASE)
    return pattern.sub(f"{gender} \\1", sentence, count=1)

def translate(text: str, target_lang: str = TARGET_LANG) -> str:
    """
    Translates text using Google Translate (googletrans).
    Returns the translated string.
    """
    try:
        result = translator.translate(text, dest=target_lang)
        return result.text
    except Exception as e:
        print(f"Translation error for '{text}': {e}")
        return "[TRANSLATION_FAILED]"

# 3. Main Translation Pipeline
def process_sentence(sentence: str) -> List[Tuple[str, str]]:
    """
    Processes a single sentence:
    - Detects ambiguity.
    - If ambiguous: injects male/female markers, translates both, returns two pairs.
    - If unambiguous: translates original, returns one pair (original, translation).

    Returns: list of (variant_sentence, translation)
    """
    sentence = sentence.strip()
    if not sentence:
        return []

    ambiguous = is_ambiguous(sentence)
    if not ambiguous:
        # Unambiguous: just translate the original sentence
        trans = translate(sentence)
        return [(sentence, trans)]

    # Ambiguous: locate the occupation
    occupation = find_occupation(sentence)
    if occupation is None:
        # No occupation found → cannot inject gender, just translate as is
        trans = translate(sentence)
        return [(sentence, trans)]

    # Generate male and female variants
    male_sent = inject_gender(sentence, occupation, "male")
    female_sent = inject_gender(sentence, occupation, "female")

    male_trans = translate(male_sent)
    female_trans = translate(female_sent)

    return [(male_sent, male_trans), (female_sent, female_trans)]

def process_dataset(sentences: List[str]) -> List[dict]:
    """
    Processes a list of sentences and returns structured results.
    """
    results = []
    for idx, sent in enumerate(sentences):
        outputs = process_sentence(sent)
        results.append({
            "original": sent,
            "ambiguous": is_ambiguous(sent),
            "variants": outputs   # list of (modified_sentence, translation)
        })
    return results

# 4. Example Usage with Dataset

if __name__ == "__main__":
    input_sentences = load_sentences("../data/eval_inputs.txt")
    print(f"Loaded {len(input_sentences)} sentences from data/eval_inputs.txt\n")
    
    results = process_dataset(input_sentences)

    print("GENDER‑AWARE TRANSLATION RESULTS (French)")
    
    for res in results:
        print(f"\nOriginal: {res['original']}")
        print(f"Ambiguous: {res['ambiguous']}")
        for variant, trans in res['variants']:
            print(f"  → {variant:45} => {trans}")
        print("-" * 100)
